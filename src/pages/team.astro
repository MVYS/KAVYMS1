---
import Base from '../layouts/Base.astro';
---
<Base title="Team" description="Current KAVYMS team.">
  <h1 class="section-title">Our Team</h1>
  <p style="text-align:center;color:var(--color-text-soft);max-width:680px;margin:0 auto 32px">
    The volunteers driving KAVYMS forward today.
  </p>
  <div class="grid" data-grid>
    <div class="state state-loading">Loading team…</div>
  </div>
</Base>

<script>
  import { fetchSheet } from '../lib/sheets';
  import { renderTeamCard, type TeamRow } from '../lib/cards';
  import { showEmpty, showError, isTruthy } from '../lib/dom';

  const root = document.querySelector<HTMLElement>('[data-grid]')!;
  fetchSheet<TeamRow>('team')
    .then((rows) => {
      const current = rows.filter((r) => isTruthy(r['Current Team']) && r.Name);
      if (current.length === 0) { showEmpty(root, 'No current team members marked. Set Current Team = TRUE in the Team sheet.'); return; }
      root.innerHTML = '';
      for (const r of current) root.appendChild(renderTeamCard(r));
    })
    .catch((e) => showError(root, e));
</script>
