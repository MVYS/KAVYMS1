---
// Vasavi Devi background image rendered as a soft, fixed watermark behind all content.
// Image lives at public/background.svg — replace with the real asset (PNG/JPG/SVG).
const base = import.meta.env.BASE_URL;
---
<div class="bg-watermark" aria-hidden="true" style={`background-image: url('${base}background.svg')`}></div>
