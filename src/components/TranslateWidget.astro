---
// Google Translate website widget — drop-in language switcher.
// Translates English source to Telugu and Kannada (extend `includedLanguages` to add more).
---
<div id="google_translate_element"></div>

<script is:inline>
  function googleTranslateElementInit() {
    new google.translate.TranslateElement(
      {
        pageLanguage: 'en',
        includedLanguages: 'en,te,kn,hi',
        layout: google.translate.TranslateElement.InlineLayout.SIMPLE,
        autoDisplay: false,
      },
      'google_translate_element'
    );
  }
</script>
<script is:inline src="https://translate.google.com/translate_a/element.js?cb=googleTranslateElementInit" async></script>
